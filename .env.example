# Copy to .env.local (local dev) or set in Render environment variables (production).
# Never commit secrets.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Supabase — server-side (Route Handlers, scripts) ─────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL for running migrations via psql or Supabase CLI
# DATABASE_URL=

# ── Supabase — browser (dashboard client; safe to expose) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Encryption key (AES-256-GCM) ──────────────────────────────────────────────
# Used for ghl_connections.private_integration_token_encrypted and
# integration_accounts.client_secret_encrypted.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GHL_CONNECTION_TOKEN_ENCRYPTION_KEY=

# ── GHL webhook + sync ────────────────────────────────────────────────────────
# Per-project tokens are stored encrypted in ghl_connections (migration 010).
# The vars below are optional fallbacks used only when no ghl_connections row matches.
# GHL_PRIVATE_INTEGRATION_TOKEN=
# GHL_LOCATION_ID=
# GHL_API_VERSION_CONTACTS=2021-07-28
# GHL_API_VERSION_PAYMENTS=2021-07-28
# GHL_THROTTLE_MS=80
# GHL_DETAIL_CONCURRENCY=8
# GHL_RATE_LIMIT_RETRIES=6
# GHL_RATE_LIMIT_BACKOFF_MS=800
# GHL_ORDERS_LIST_PATH=/payments/orders/
# GHL_ORDERS_DETAIL_PATH_TEMPLATE=/payments/orders/{id}
# GHL_INVOICES_LIST_PATH=/invoices/
# GHL_INVOICES_DETAIL_PATH_TEMPLATE=/invoices/{id}
# Skip signature verification in local dev only (never in production):
# GHL_WEBHOOK_SKIP_VERIFY=true

# ── Google OAuth (Sheets integration — optional) ──────────────────────────────
# Routes return 501 if these are absent. Not required for Phase 1.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Traffic dashboard (legacy single-location config) ─────────────────────────
# Multi-project uses projects.traffic_* columns instead of these env vars.
# NEXT_PUBLIC_TRAFFIC_KEY=
# TRAFFIC_AGENCY_LINE_TAGS_JSON={"OM":["lead_om"],"NM":["lead_nm"]}
# TRAFFIC_OCCUPATION_FIELD_ID=
# TRAFFIC_DASHBOARD_API_KEY=
# TRAFFIC_BACKFILL_AFTER_FULL_SYNC=1

# ── Render cron sync (production only) ────────────────────────────────────────
# Set on the nmdabn-ghl-daily-sync cron service in Render, not the web service.
# SYNC_HOST=https://your-app.onrender.com
# SYNC_BEARER_TOKEN=   # Supabase JWT for a service account with workspace access
# SYNC_WORKSPACE_ID=   # UUID of the workspace to sync
