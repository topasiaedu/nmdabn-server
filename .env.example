# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000
NODE_ENV=development

# Supabase (regenerate src/database.types.ts when the new project/schema is ready)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Sheets integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# GHL → Supabase normalized contact sync + webhooks (run docs/database/migrations/003 first)
# GHL_PRIVATE_INTEGRATION_TOKEN=
# GHL_LOCATION_ID=
# GHL_API_VERSION_CONTACTS=2021-07-28
# GHL_API_VERSION_PAYMENTS=2021-07-28
# GHL_THROTTLE_MS=80
# GHL_DETAIL_CONCURRENCY=8
# GHL_RATE_LIMIT_RETRIES=6
# GHL_RATE_LIMIT_BACKOFF_MS=800
# Optional endpoint overrides for orders/invoices sync script
# GHL_ORDERS_LIST_PATH=/payments/orders/
# GHL_ORDERS_DETAIL_PATH_TEMPLATE=/payments/orders/{id}
# GHL_INVOICES_LIST_PATH=/invoices/
# GHL_INVOICES_DETAIL_PATH_TEMPLATE=/invoices/{id}
# Optional: skip X-GHL-Signature / X-WH-Signature checks (local dev only; never in production)
# GHL_WEBHOOK_SKIP_VERIFY=true

# Traffic dashboard (migrations 006–007)
# TRAFFIC_AGENCY_LINE_TAGS_JSON={"OM":["lead_om"],"NM":["lead_nm"]}
# TRAFFIC_OCCUPATION_FIELD_ID=   # legacy Traffic API only; multi-project uses projects.traffic_occupation_field_id
# TRAFFIC_DASHBOARD_API_KEY=
# FRONTEND_ORIGIN=http://localhost:5173
# TRAFFIC_BACKFILL_AFTER_FULL_SYNC=1
