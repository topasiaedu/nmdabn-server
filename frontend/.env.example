# Copy to frontend/.env.local

# Supabase Auth (required for login screen)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional API base; leave empty to call relative /api
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Only for legacy traffic key mode
# NEXT_PUBLIC_TRAFFIC_KEY=
