{
  "name": "nmdabn-server",
  "version": "1.0.0",
  "description": "NMDABN backend API (Express + TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "dev:frontend": "npm run dev --prefix frontend",
    "sync-ghl-contacts": "node --env-file=.env scripts/sync-ghl-contacts-to-supabase.mjs",
    "sync-ghl-orders-invoices": "node --env-file=.env scripts/sync-ghl-orders-invoices-to-supabase.mjs",
    "backfill-webinar-runs": "node --env-file=.env scripts/backfill-webinar-runs.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^129.0.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
